{
  "name": "video-deck",
  "version": "1.0.0",
  "description": "最优秀的电影管理软件",
  "main": "main.js",
  "bin": {
    "movie-mgt": "./src/cli/index.js"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "test": "jest",
    "test:unit": "jest",
    "test:gui": "wdio run ./wdio.conf.ts",
    "test:cli": "jest --config test/cli/jest.config.js",
    "build:gui": "electron-builder --win",
    "build:cli": "npx pkg src/cli/index.js --targets node18-win --output dist/movie-mgt-cli.exe",
    "build:cli:all": "npx pkg src/cli/index.js --targets node18-win,node18-linux,node18-macos --output dist/movie-mgt-cli"
  },
  "keywords": [
    "movie",
    "electron",
    "manager"
  ],
  "author": "Yugeng Hui",
  "license": "Apache 2.0",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/node": "^25.5.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "expect-webdriverio": "^5.6.5",
    "jest": "^29.7.0",
    "pkg": "^5.8.1",
    "wdio-electron-service": "^9.2.1"
  },
  "dependencies": {
    "archiver": "^5.3.0",
    "chalk": "^4.1.0",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "electron-log": "^5.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "https-proxy-agent": "^7.0.6",
    "inquirer": "^8.2.0",
    "ora": "^5.4.0",
    "pg": "^8.20.0",
    "xml2js": "^0.6.2"
  },
  "build": {
    "appId": "org.pinae.video-deck",
    "productName": "video-deck",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "dir"
      ],
      "icon": "assets/icon.ico"
    }
  }
}
